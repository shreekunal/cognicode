# ==============================================================================
# CogniCode — Environment Variables Example
# Rename this file to .env and fill in your values.
# ==============================================================================

# 1. DATABASE
# MongoDB Atlas Connection String
# Example: mongodb+srv://user:pass@cluster.mongodb.net/cognicode
MONGO_URL=mongodb://localhost:27017/cognicode

# 2. NEXTAUTH CONFIG
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
# Production URL (e.g., https://cognicode.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# 3. AI BACKEND (PYTHON)
# The URL where your Python backend is hosted (Render URL in production)
PYTHON_BACKEND_URL=http://localhost:8000

# 4. LLM API KEYS (REQUIRED for AI features)
# You can use OpenAI or Groq (OpenAI-compatible)
OPENAI_API_KEY=
# Optional: Override base URL for Groq or other providers
# OPENAI_API_BASE=https://api.groq.com/openai/v1
# OPENAI_MODEL=gpt-4o-mini

# 5. FRONTEND URL (For CORS in Python Backend)
# Production URL of your Vercel deployment
FRONTEND_URL=http://localhost:3000

# 6. CODE EXECUTION (Optional, defaults to OneCompiler)
# Get a key from https://onecompiler.com/apis/code-execution
ONECOMPILER_API_KEY=

# 7. GITHUB AUTH (Optional, if using GitHub Login)
# GITHUB_ID=
# GITHUB_SECRET=
