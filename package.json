{
  "name": "cognicode",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "init-db": "node utils/initDatabase.js",
    "python": "cd python-backend && python3 main.py",
    "mongodb": "sudo systemctl enable mongod && sudo systemctl start mongod",
    "dev:all": "concurrently -n mongodb,next,python -c green,blue,yellow \"npm run mongodb\" \"npm run dev\" \"npm run python\"",
    "stop": "pkill -f 'next dev' ; pkill -f 'python3 main.py' ; sudo systemctl stop mongod ; echo 'Stopped all servers'"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-python": "^6.2.1",
    "@uiw/codemirror-theme-eclipse": "^4.25.4",
    "@uiw/codemirror-theme-vscode": "^4.25.4",
    "@uiw/react-codemirror": "^4.25.4",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "gsap": "^3.14.2",
    "js-cookie": "^3.0.5",
    "mongoose": "^9.1.5",
    "next": "^16.1.4",
    "next-auth": "^4.24.13",
    "react": "^18",
    "react-confetti": "^6.4.0",
    "react-dom": "^18",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-multi-carousel": "^2.8.6",
    "react-select": "^5.10.2",
    "react-split": "^2.0.14",
    "react-toastify": "^11.0.5",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "eslint": "9.39.2",
    "eslint-config-next": "16.1.4",
    "postcss": "^8",
    "tailwindcss": "^3.4.17"
  }
}
